# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL 18)
DATABASE_URL="postgresql://db_user:db_password@localhost:5432/db_name?schema=public"

# Authentication Secrets
JWT_ACCESS_SECRET="your_jwt_access_secret_change_me_in_production"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_change_me_in_production"
JWT_REFRESH_EXPIRATION="7d"

# Storage Settings
# Options: local | s3
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH="./uploads"

# S3 Configuration (Used if STORAGE_PROVIDER=s3)
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION=""
S3_BUCKET_NAME=""
